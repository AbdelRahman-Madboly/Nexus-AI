# =============================================================================
# NEXUS-AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — only .env.example is committed.
#
# Rule: ALL LLM calls go through api/llm/llm_router.py.
#       Switching backend = change LLM_BACKEND below. Zero code changes.
# =============================================================================


# =============================================================================
# LLM BACKEND SELECTION
# =============================================================================
# Which LLM provider to use: openai | claude | gemini | ollama
LLM_BACKEND=gemini

# Set to true to force ALL calls to Ollama regardless of LLM_BACKEND.
# Use this when handling sensitive client data. No data leaves your machine.
PRIVACY_MODE=false


# =============================================================================
# GEMINI (Primary Cloud Backend)
# =============================================================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash


# =============================================================================
# OPENAI (Optional Cloud Backend)
# =============================================================================
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o


# =============================================================================
# ANTHROPIC / CLAUDE (Optional Cloud Backend)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your-claude-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514


# =============================================================================
# OLLAMA (Local / Privacy Backend)
# =============================================================================
# Used when PRIVACY_MODE=true OR LLM_BACKEND=ollama
# On your laptop: http://localhost:11434
# Inside Docker Compose: http://nexus-ollama:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Pull these models before running:
#   ollama pull llama3.1:8b        (main LLM — good quality, fits 8GB VRAM)
#   ollama pull llama3.2:3b        (fast/lightweight — used by OpenClaw)
#   ollama pull nomic-embed-text   (embeddings for RAG — only 274MB)


# =============================================================================
# DATABASE
# =============================================================================
# SQLite file path. WAL mode is enabled automatically by database.py.
# Relative path = stored in project root next to docker-compose.yml.
DATABASE_URL=sqlite:///./nexus.db


# =============================================================================
# CHROMADB (Vector Store for RAG)
# =============================================================================
# On your laptop (direct): localhost
# Inside Docker Compose: nexus-chroma
CHROMA_HOST=localhost
CHROMA_PORT=8001


# =============================================================================
# AUTH
# =============================================================================
# Change this to a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-32-char-string-in-production
JWT_ALGORITHM=HS256


# =============================================================================
# N8N AUTOMATION
# =============================================================================
N8N_WEBHOOK_URL=http://localhost:5678


# =============================================================================
# OPENCLAW GATEWAY
# =============================================================================
# OpenClaw runs as a separate process (not in Docker for local dev).
# It connects to Nexus API via HTTP on this URL.
OPENCLAW_MODEL=ollama/llama3.2:3b
OPENCLAW_CLOUD_FALLBACK=false
OPENCLAW_NEXUS_API_URL=http://localhost:8000

# Telegram Bot — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Twilio — for WhatsApp channel (optional)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Slack — for Slack channel (optional)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token


# =============================================================================
# FASTAPI SERVER
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

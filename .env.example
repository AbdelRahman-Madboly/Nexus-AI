# ============================================================
# Nexus-AI Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# === LLM Backend ===
# Options: openai | claude | gemini | ollama
LLM_BACKEND=ollama

# If true, ALL LLM calls route to Ollama regardless of LLM_BACKEND
PRIVACY_MODE=true

# === OpenAI ===
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# === Anthropic ===
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# === Google ===
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.5-flash

# === Ollama ===
OLLAMA_BASE_URL=http://nexus-ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# === Database ===
DATABASE_URL=sqlite:///./nexus.db

# === ChromaDB ===
CHROMA_HOST=nexus-chroma
CHROMA_PORT=8001

# === Auth ===
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# === n8n ===
N8N_WEBHOOK_URL=http://nexus-n8n:5678
N8N_API_KEY=your-n8n-api-key

# === OpenClaw Gateway ===
# Model for the OpenClaw agent (local Ollama by default)
OPENCLAW_MODEL=ollama/llama3.2:3b
# Set to true to allow cloud LLM fallback from OpenClaw
OPENCLAW_CLOUD_FALLBACK=false
# URL OpenClaw uses to call Nexus API
OPENCLAW_NEXUS_API_URL=http://nexus-api:8000

# Telegram channel (get token from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# WhatsApp via Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=whatsapp:+14155238886

# Slack (create app at api.slack.com)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token

# === Frontend ===
VITE_API_BASE_URL=http://localhost:8000
